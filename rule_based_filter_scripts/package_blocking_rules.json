{
  "package_blocking_rules": {
    "Python": {
      "exclude_imports": [
        "torch",
        "tensorflow",
        "keras",
        "sklearn",
        "scipy",
        "matplotlib",
        "seaborn",
        "plotly",
        "cv2",
        "PIL",
        "openai",
        "tkinter",
        "PyQt5",
        "PyQt6",
        "PySide2",
        "PySide6",
        "kivy",
        "psutil",
        "win32api",
        "win32gui",
        "ctypes",
        "sqlalchemy",
        "django.db",
        "peewee",
        "asyncio",
        "aiohttp",
        "celery",
        "sympy",
        "statsmodels",
        "networkx"
      ],
      "exclude_keywords": [
        "__pycache__",
        ".pyc"
      ]
    },
    "JavaScript": {
      "exclude_imports": [
        "react",
        "vue",
        "angular",
        "@angular",
        "svelte",
        "express",
        "koa",
        "fastify",
        "nest",
        "webpack",
        "vite",
        "rollup",
        "parcel",
        "antd",
        "material-ui",
        "@mui",
        "bootstrap",
        "redux",
        "mobx",
        "vuex",
        "pinia",
        "jquery",
        "lodash",
        "underscore",
        "jest",
        "mocha",
        "cypress",
        "playwright"
      ],
      "exclude_keywords": [
        "node_modules",
        ".npm",
        "yarn.lock"
      ]
    },
    "Java": {
      "exclude_imports": [
        "org.springframework",
        "springframework",
        "android",
        "androidx",
        "javax.servlet",
        "jakarta.servlet",
        "javax.swing",
        "java.awt",
        "javafx",
        "hibernate",
        "mybatis",
        "struts",
        "org.apache.spark",
        "org.apache.hadoop",
        "org.apache.kafka",
        "rabbitmq"
      ],
      "exclude_keywords": [
        ".class",
        "META-INF"
      ]
    },
    "C++": {
      "exclude_imports": [
        "Qt",
        "gtk",
        "wxWidgets",
        "FLTK",
        "unreal",
        "unity",
        "ogre",
        "OpenGL",
        "DirectX",
        "Vulkan",
        "windows.h",
        "win32",
        "linux",
        "boost/asio",
        "poco",
        "opencv",
        "eigen",
        "armadillo"
      ],
      "exclude_keywords": [
        ".dll"
      ]
    },
    "C": {
      "exclude_imports": [
        "windows.h",
        "unistd.h",
        "sys/",
        "gtk",
        "qt",
        "socket.h",
        "netinet",
        "pthread.h",
        "sqlite3.h",
        "mysql.h"
      ],
      "exclude_keywords": [
        ".dll",
        ".a"
      ]
    },
    "C#": {
      "exclude_imports": [
        "System.Windows",
        "Microsoft",
        "ASP.NET",
        "Blazor",
        "WPF",
        "WinForms",
        "MAUI",
        "Unity",
        "MonoGame",
        "Entity Framework",
        "Dapper"
      ],
      "exclude_keywords": [
        "bin/",
        "obj/"
      ]
    },
    "Go": {
      "exclude_imports": [
        "gin",
        "echo",
        "fiber",
        "beego",
        "grpc",
        "protobuf",
        "gorm",
        "sqlx",
        "syscall",
        "os/exec",
        "net/http",
        "gorilla"
      ],
      "exclude_keywords": [
        "vendor/"
      ]
    },
    "Rust": {
      "exclude_imports": [
        "actix",
        "rocket",
        "warp",
        "axum",
        "egui",
        "tauri",
        "gtk",
        "tokio",
        "async-std",
        "winapi",
        "libc",
        "serde",
        "bincode"
      ],
      "exclude_keywords": [
        "target/"
      ]
    }
  }
}
